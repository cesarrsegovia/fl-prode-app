{
  "name": "prode",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @prode/api exec prisma generate",
    "db:migrate": "pnpm --filter @prode/api exec prisma migrate dev",
    "db:push": "pnpm --filter @prode/api exec prisma db push",
    "db:seed": "pnpm --filter @prode/api run db:seed",
    "db:reset": "pnpm --filter @prode/api exec prisma migrate reset"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
