# URL base de la API NestJS
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000/api
# URL del WebSocket
NEXT_PUBLIC_WS_URL=http://localhost:4000
# Orígenes del casino autorizados a embeber Prode (coma-separados, sin / final)
# Ej: https://casino.com,https://staging.casino.com. Vacío = no embebible (fail-closed).
NEXT_PUBLIC_PARENT_ORIGINS=
# Dominio público canónico para los links de invitación a grupos (sin / final).
# Evita exponer la URL del deploy de Vercel. Vacío = usa el origin del navegador.
# Ej: https://prode.miapp.com
NEXT_PUBLIC_APP_URL=
