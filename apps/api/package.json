{
  "name": "@prode/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "db:import-worldcup": "ts-node -r tsconfig-paths/register prisma/import-worldcup.ts",
    "db:seed-worldcup": "ts-node -r tsconfig-paths/register prisma/seed-worldcup.ts",
    "db:seed-squads": "ts-node -r tsconfig-paths/register prisma/seed-squads.ts",
    "db:map-espn-ids": "ts-node -r tsconfig-paths/register prisma/map-espn-ids.ts",
    "db:fix-match-times": "ts-node -r tsconfig-paths/register prisma/fix-match-times.ts"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": ["ts-jest", { "isolatedModules": true }] },
    "moduleNameMapper": {
      "^@prode/shared$": "<rootDir>/../../../packages/shared/src/index.ts"
    },
    "testEnvironment": "node"
  },
  "dependencies": {
    "@nestjs/common": "^11",
    "@nestjs/core": "^11",
    "@nestjs/jwt": "^11",
    "@nestjs/passport": "^11",
    "@nestjs/platform-express": "^11",
    "@nestjs/platform-socket.io": "^11",
    "@nestjs/schedule": "^5",
    "@nestjs/websockets": "^11",
    "@prisma/client": "^6",
    "@prode/shared": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "ioredis": "^5",
    "passport": "^0.7",
    "passport-jwt": "^4",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "socket.io": "^4"
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@nestjs/testing": "^11",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22",
    "@types/passport-jwt": "^4",
    "jest": "^29.7.0",
    "prisma": "^6",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9",
    "ts-node": "^10",
    "tsconfig-paths": "^4",
    "typescript": "^5.7"
  }
}
