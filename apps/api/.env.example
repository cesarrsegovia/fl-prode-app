DATABASE_URL=postgresql://prode:prode@localhost:5432/prode
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION=7d

# API-Football (https://www.api-football.com/). Alta gratuita en RapidAPI o api-sports.io.
# Obtener clave -> settear SPORTS_API_KEY. Dejar vacío para desactivar el cron de resultados.
# URL base por defecto para api-sports.io: https://v3.football.api-sports.io
SPORTS_API_KEY=
SPORTS_API_URL=https://v3.football.api-sports.io

# Proveedor de resultados: "espn" (default, gratis, sin key) | "apifootball" (legacy, requiere SPORTS_API_KEY)
RESULTS_PROVIDER=espn
# Base del scoreboard de ESPN (override opcional)
ESPN_SCOREBOARD_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world

FRONTEND_URL=http://localhost:3000
PORT=4000
SENTRY_DSN=

# Keep-alive de la BD (Neon free se autosuspende a los ~5 min sin actividad).
# DB_KEEPALIVE=1 -> SELECT 1 cada 4 min mientras la API corre. Recomendado en dev.
# Ojo en prod: mantiene el compute de Neon despierto y consume las compute-hours
# del plan free (~190 h/mes). Hay también GET /api/health/db para pingers externos.
DB_KEEPALIVE=

# Integración con plataforma padre (Prode = provider, llama al padre)
# Slug propio con el que el padre nos identifica en sus URLs /providers/{provider}/...
PROVIDER_NAME=prode
# Operator name que el padre nos asigna; lo enviamos en cada request
PROVIDER_OPERATOR_NAME=
# URL base del backend del padre (ej. https://gamblor.fuegolabz.io/fuego-labz)
OFFCHAIN_API_URL=
# API key con la que nos autenticamos contra el padre (X-API-Key)
PROVIDER_OUTBOUND_API_KEY=
# Timeout en ms para las requests al padre
PROVIDER_TIMEOUT_MS=10000
