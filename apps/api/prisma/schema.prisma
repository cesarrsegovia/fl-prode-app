generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USUARIOS Y GRUPOS SOCIALES
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  username     String?  @unique
  passwordHash String?
  avatarUrl    String?
  bio          String?
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  // Identidad del provider padre (cuando el usuario entra vía launch)
  providerName   String?
  providerUserId String?
  currency       String?
  locale         String?

  memberships       GroupMember[]
  scores            UserScore[]
  predictions       Prediction[]
  bracketPicks      BracketPick[]
  topScorerPicks    TopScorerPick[]
  r32Picks          R32QualifierPick[]
  notifications     Notification[]
  achievements      UserAchievement[]
  activities        Activity[]
  messages          Message[]
  providerSessions  ProviderSession[]
  walletTxs         WalletTransaction[]
  tournamentEntries TournamentEntry[]

  @@unique([providerName, providerUserId])
}

model Group {
  id          String        @id @default(cuid())
  name        String
  description String?
  inviteCode  String        @unique @default(cuid())
  isPrivate   Boolean       @default(true)
  createdAt   DateTime      @default(now())
  members     GroupMember[]
  scores      GroupScore[]
  activities  Activity[]
  messages    Message[]
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  role     Role     @default(MEMBER)
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  group    Group    @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

// ============================================================
// TORNEOS (Mundial, ligas, copas, ...)
// ============================================================

model Tournament {
  id            String         @id @default(cuid())
  externalId    String?        @unique
  name          String
  type          TournamentType @default(CUP)
  country       String?
  startDate     DateTime?
  endDate       DateTime?
  isActive      Boolean        @default(true)
  logoUrl       String?
  trophyUrl     String?
  entryFee      Decimal?       @db.Decimal(18, 4)
  entryCurrency String?
  createdAt     DateTime       @default(now())

  // Predicción de goleador del torneo
  topScorerPlayerId String?
  topScorerDeadline DateTime?

  fixtures        Fixture[]
  matches         Match[]
  groups          TournamentGroup[]
  teams           TournamentTeam[]
  squads          SquadEntry[]
  standings       GroupStanding[]
  scores          GroupScore[]
  userScores      UserScore[]
  bracketPicks    BracketPick[]
  r32Picks        R32QualifierPick[]
  entries         TournamentEntry[]
  walletTxs       WalletTransaction[]
  topScorerWinner Player?        @relation("TournamentTopScorer", fields: [topScorerPlayerId], references: [id])
  topScorerPicks  TopScorerPick[]
}

model TournamentGroup {
  id           String  @id @default(cuid())
  tournamentId String
  externalId   String? @unique
  name         String // "A", "B", ..., "L"

  tournament Tournament       @relation(fields: [tournamentId], references: [id])
  teams      TournamentTeam[]
  matches    Match[]
  standings  GroupStanding[]

  @@unique([tournamentId, name])
}

model Team {
  id             String  @id @default(cuid())
  externalId     String? @unique
  name           String
  shortName      String? // "ARG"
  code           String? // "AR" o ISO-2
  flagUrl        String?
  logoUrl        String?
  founded        Int?
  primaryColor   String?
  secondaryColor String?
  confederation  String? // "CONMEBOL", "UEFA", "CONCACAF", ...

  tournamentTeams TournamentTeam[]
  homeMatches     Match[]          @relation("HomeTeamMatches")
  awayMatches     Match[]          @relation("AwayTeamMatches")
  squad           SquadEntry[]
  standings       GroupStanding[]
  bracketPicks    BracketPick[]
  r32Picks        R32QualifierPick[]
}

model TournamentTeam {
  id           String  @id @default(cuid())
  tournamentId String
  teamId       String
  groupId      String? // null para torneos sin grupos
  fifaRanking  Int?

  tournament Tournament       @relation(fields: [tournamentId], references: [id])
  team       Team             @relation(fields: [teamId], references: [id])
  group      TournamentGroup? @relation(fields: [groupId], references: [id])

  @@unique([tournamentId, teamId])
}

model Venue {
  id         String  @id @default(cuid())
  externalId String? @unique
  name       String
  city       String?
  country    String?
  capacity   Int?
  imageUrl   String?
  latitude   Float?
  longitude  Float?
  surface    String?

  matches Match[]
}

model Player {
  id          String  @id @default(cuid())
  externalId  String? @unique
  name        String
  position    String? // "Goalkeeper", "Defender", "Midfielder", "Attacker"
  number      Int?
  photoUrl    String?
  age         Int?
  nationality String?
  isStaff     Boolean @default(false) // cuerpo técnico (DT, asistente): no es candidato a goleador
  role        String? // rol original en español cuando isStaff: "Entrenador", "Asistente técnico", ...

  squad           SquadEntry[]
  topScorerOf     Tournament[]    @relation("TournamentTopScorer")
  topScorerPicks  TopScorerPick[]
}

model SquadEntry {
  id           String @id @default(cuid())
  tournamentId String
  teamId       String
  playerId     String

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  team       Team       @relation(fields: [teamId], references: [id])
  player     Player     @relation(fields: [playerId], references: [id])

  @@unique([tournamentId, teamId, playerId])
}

// ============================================================
// FIXTURES (matchdays) Y PARTIDOS
// ============================================================

model Fixture {
  id           String       @id @default(cuid())
  tournamentId String
  round        Int // matchday: 1, 2, 3 (grupos), 4 (R32), 5 (R16), 6 (QF), 7 (SF), 8 (3rd), 9 (Final)
  name         String? // "Fase de Grupos - Fecha 1", "Octavos", "Final", ...
  closeAt      DateTime
  tournament   Tournament   @relation(fields: [tournamentId], references: [id])
  matches      Match[]
  predictions  Prediction[]

  @@unique([tournamentId, round])
}

model Match {
  id           String     @id @default(cuid())
  externalId   String?    @unique
  tournamentId String
  fixtureId    String
  stage        MatchStage @default(GROUP)
  groupId      String?
  venueId      String?

  // Equipos: FK + denormalizado para UI rápida
  homeTeamId   String?
  awayTeamId   String?
  homeTeamName String // copia denormalizada (puede ser "Ganador Grupo A" antes de definirse)
  awayTeamName String

  startTime DateTime
  status    MatchStatus @default(PENDING)

  // Marcadores: 90', alargue, penales
  homeScore   Int?
  awayScore   Int?
  homeScoreET Int?
  awayScoreET Int?
  homePens    Int?
  awayPens    Int?

  refereeName  String?
  attendance   Int?
  broadcasters Json?

  tournament  Tournament       @relation(fields: [tournamentId], references: [id])
  fixture     Fixture          @relation(fields: [fixtureId], references: [id])
  group       TournamentGroup? @relation(fields: [groupId], references: [id])
  venue       Venue?           @relation(fields: [venueId], references: [id])
  homeTeam    Team?            @relation("HomeTeamMatches", fields: [homeTeamId], references: [id])
  awayTeam    Team?            @relation("AwayTeamMatches", fields: [awayTeamId], references: [id])
  predictions Prediction[]
}

// Standings de grupo (cacheado, recalculado al cerrar partidos)
model GroupStanding {
  id           String @id @default(cuid())
  tournamentId String
  groupId      String
  teamId       String
  played       Int    @default(0)
  won          Int    @default(0)
  drawn        Int    @default(0)
  lost         Int    @default(0)
  goalsFor     Int    @default(0)
  goalsAgainst Int    @default(0)
  goalDiff     Int    @default(0)
  points       Int    @default(0)
  position     Int    @default(0)

  tournament Tournament      @relation(fields: [tournamentId], references: [id])
  group      TournamentGroup @relation(fields: [groupId], references: [id])
  team       Team            @relation(fields: [teamId], references: [id])

  @@unique([groupId, teamId])
}

// ============================================================
// PREDICCIONES
// ============================================================

model Prediction {
  id             String   @id @default(cuid())
  userId         String
  matchId        String
  fixtureId      String
  result         Result
  homeScoreGuess Int?
  awayScoreGuess Int?
  isCaptain      Boolean  @default(false)
  pointsEarned   Int?
  createdAt      DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  match   Match   @relation(fields: [matchId], references: [id])
  fixture Fixture @relation(fields: [fixtureId], references: [id])

  @@unique([userId, matchId])
  // calculatePoints filtra por (fixtureId, pointsEarned IS NULL); el cron
  // de "fixture closing" hace distinct userId por fixtureId.
  @@index([fixtureId, pointsEarned])
  @@index([fixtureId, userId])
}

// Predicción de los 32 equipos que clasifican a R32 (Round of 32 / "16vos de final")
// Cada usuario manda 24 picks TOP2 (2 por cada uno de los 12 grupos) + 8 BEST_THIRD.
// Deadline = día previo al inicio de la 3ra fecha de grupos.
model R32QualifierPick {
  id           String      @id @default(cuid())
  userId       String
  tournamentId String
  teamId       String
  kind         R32PickKind
  pointsEarned Int?
  createdAt    DateTime    @default(now())

  user       User       @relation(fields: [userId], references: [id])
  tournament Tournament @relation(fields: [tournamentId], references: [id])
  team       Team       @relation(fields: [teamId], references: [id])

  @@unique([userId, tournamentId, teamId])
  @@index([userId, tournamentId])
}

// Predicción de campeón del torneo (bonus al final)
model BracketPick {
  id           String   @id @default(cuid())
  userId       String
  tournamentId String
  champTeamId  String // equipo que pickea como campeón
  pointsEarned Int?
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  tournament Tournament @relation(fields: [tournamentId], references: [id])
  champTeam  Team       @relation(fields: [champTeamId], references: [id])

  @@unique([userId, tournamentId])
}

// Predicción del goleador del torneo (bonus al final)
model TopScorerPick {
  id           String   @id @default(cuid())
  userId       String
  tournamentId String
  playerId     String
  pointsEarned Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  tournament Tournament @relation(fields: [tournamentId], references: [id])
  player     Player     @relation(fields: [playerId], references: [id])

  @@unique([userId, tournamentId])
}

// ============================================================
// PUNTAJES POR GRUPO (social)
// ============================================================

model GroupScore {
  id           String @id @default(cuid())
  groupId      String
  userId       String
  tournamentId String
  total        Int    @default(0)
  streak       Int    @default(0)
  correctWinners    Int       @default(0)
  exactScores       Int       @default(0)
  exactGoalsSum     Int       @default(0)
  firstPredictionAt DateTime?

  group      Group      @relation(fields: [groupId], references: [id])
  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([groupId, userId, tournamentId])
  // getGroupRanking / snapshotPositions ordenan por (groupId, tournamentId).
  @@index([groupId, tournamentId])
  // applyScoreDeltas y stats por usuario buscan por (userId, tournamentId).
  @@index([userId, tournamentId])
}

// Puntaje global del usuario por torneo, independiente de grupos.
// Se actualiza para TODO usuario que suma puntos (tenga grupo o no),
// y es la fuente del ranking global.
model UserScore {
  id           String @id @default(cuid())
  userId       String
  tournamentId String
  total        Int    @default(0)
  streak       Int    @default(0)
  correctWinners    Int       @default(0)
  exactScores       Int       @default(0)
  exactGoalsSum     Int       @default(0)
  firstPredictionAt DateTime?

  user       User       @relation(fields: [userId], references: [id])
  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([userId, tournamentId])
  // getGlobalRanking / globalPositions ordenan por (tournamentId, total desc).
  @@index([tournamentId, total])
}

// ============================================================
// NOTIFICACIONES Y ACHIEVEMENTS
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  message   String // fallback en español (legacy y por si el front no reconoce la key)
  payload   Json? // { key, params } para traducir en el front
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  // findByUser ordena por createdAt; markAllRead filtra por (userId, read).
  @@index([userId, createdAt])
  @@index([userId, read])
}

model Achievement {
  id          String            @id @default(cuid())
  key         String            @unique
  name        String
  description String
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

// ============================================================
// ACTIVITY FEED (social engagement)
// ============================================================

model Activity {
  id        String       @id @default(cuid())
  groupId   String
  userId    String
  type      ActivityType
  message   String
  payload   Json?
  createdAt DateTime     @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([groupId, createdAt])
  @@index([userId, createdAt])
}

// ============================================================
// CHAT DE GRUPO
// ============================================================

model Message {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  content   String   @db.VarChar(2000)
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([groupId, createdAt])
}

// ============================================================
// INTEGRACIÓN PROVIDER PADRE (launch / wallet)
// ============================================================

model ProviderSession {
  id                String    @id @default(cuid())
  providerName      String
  operatorName      String?
  authorizationCode String    @unique
  userId            String?
  providerUserId    String?
  currency          String?
  locale            String?
  isMobile          Boolean   @default(false)
  demo              Boolean   @default(false)
  referrer          String?
  expiresAt         DateTime?
  consumedAt        DateTime?
  exchangedAt       DateTime?
  createdAt         DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([providerName, providerUserId])
}

model WalletTransaction {
  id                   String          @id @default(cuid())
  userId               String
  providerName         String
  direction            WalletDirection
  amount               Decimal         @db.Decimal(18, 4)
  currency             String
  transactionRequestId String          @unique
  eventId              String?
  gameId               String?
  gameType             String?
  roundId              String?
  refTransactionId     String?
  status               WalletTxStatus  @default(PENDING)
  errorCode            String?
  errorDetail          String?
  tournamentId         String?
  fixtureId            String?
  createdAt            DateTime        @default(now())

  user          User             @relation(fields: [userId], references: [id])
  tournament    Tournament?      @relation(fields: [tournamentId], references: [id])
  entryAsDebit  TournamentEntry? @relation("EntryDebit")
  entryAsCredit TournamentEntry? @relation("EntryCredit")

  @@index([userId, createdAt])
  @@index([tournamentId])
  @@index([roundId])
}

model TournamentEntry {
  id           String                @id @default(cuid())
  userId       String
  tournamentId String
  debitTxId    String?               @unique
  creditTxId   String?               @unique
  amount       Decimal               @db.Decimal(18, 4)
  currency     String
  status       TournamentEntryStatus @default(PAID)
  createdAt    DateTime              @default(now())

  user       User               @relation(fields: [userId], references: [id])
  tournament Tournament         @relation(fields: [tournamentId], references: [id])
  debitTx    WalletTransaction? @relation("EntryDebit", fields: [debitTxId], references: [id])
  creditTx   WalletTransaction? @relation("EntryCredit", fields: [creditTxId], references: [id])

  @@unique([userId, tournamentId])
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  MEMBER
}

enum TournamentType {
  LEAGUE
  CUP
  INTERNATIONAL
}

enum MatchStage {
  GROUP
  R32
  R16
  QUARTERFINAL
  SEMIFINAL
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  PENDING
  LIVE
  FINISHED
  CANCELLED
}

enum Result {
  HOME
  DRAW
  AWAY
}

enum NotificationType {
  FIXTURE_CLOSING
  RESULT_CALCULATED
  RANKING_CHANGE
  GROUP_INVITE
  ACHIEVEMENT_UNLOCKED
}

enum ActivityType {
  MEMBER_JOINED
  PREDICTIONS_SUBMITTED
  POINTS_EARNED
  RANK_UP
  BRACKET_PICK
  ACHIEVEMENT_UNLOCKED
}

enum WalletDirection {
  DEBIT
  CREDIT
}

enum WalletTxStatus {
  PENDING
  OK
  FAILED
  REVERSED
}

enum TournamentEntryStatus {
  PAID
  REFUNDED
  SETTLED
}

enum R32PickKind {
  TOP2
  BEST_THIRD
}
